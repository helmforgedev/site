---
import ThemeToggle from './ThemeToggle.astro';
import Logo from './Logo.astro';
import Container from './Container.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { Github, Menu, X, Search, ChevronDown } from 'lucide-astro';

const currentPath = Astro.url.pathname;

interface NavLink {
  label: string;
  href: string;
  description?: string;
}

interface NavDropdown {
  label: string;
  items: NavLink[];
}

type NavEntry = NavLink | NavDropdown;

function isDropdown(entry: NavEntry): entry is NavDropdown {
  return 'items' in entry;
}

const navEntries: NavEntry[] = [
  { label: 'Docs', href: '/docs' },
  { label: 'Blog', href: '/blog' },
  {
    label: 'Tools',
    items: [
      { label: 'Stack Builder', href: '/stack', description: 'Compose chart stacks visually' },
      { label: 'Playground', href: '/playground', description: 'Configure and preview values' },
    ],
  },
  {
    label: 'Community',
    items: [
      { label: 'Roadmap', href: '/roadmap', description: 'Track what\u2019s coming next' },
      { label: 'Changelog', href: '/changelog', description: 'Release notes from GitHub' },
      { label: 'Request a Chart', href: '/request', description: 'Suggest a new chart' },
      { label: 'Community', href: '/community', description: 'Contributors and links' },
    ],
  },
];

// Flatten for mobile
const mobileItems: NavLink[] = [
  { label: 'Docs', href: '/docs' },
  { label: 'Blog', href: '/blog' },
  { label: 'Stack Builder', href: '/stack' },
  { label: 'Playground', href: '/playground' },
  { label: 'Roadmap', href: '/roadmap' },
  { label: 'Changelog', href: '/changelog' },
  { label: 'Request a Chart', href: '/request' },
  { label: 'Community', href: '/community' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}

function isDropdownActive(items: NavLink[]): boolean {
  return items.some((item) => isActive(item.href));
}
---

<header
  class="header-glass sticky top-0 z-50 border-b border-border shadow-[0_4px_30px_rgba(0,0,0,0.05)] transition-all"
>
  <Container>
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center group text-text-base transition-opacity hover:opacity-90"
        aria-label="HelmForge home"
        data-i18n-attr="aria-label"
        data-i18n-key="header.home"
      >
        <Logo
          variant="horizontal"
          class="h-8 sm:h-9 w-auto transition-transform duration-300 group-hover:scale-[1.02]"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-0.5" aria-label="Main navigation">
        {
          navEntries.map((entry) =>
            isDropdown(entry) ? (
              <div class="nav-dropdown relative">
                <button
                  type="button"
                  class:list={[
                    'nav-dropdown-trigger flex items-center gap-1 px-3 py-2 text-sm font-medium transition-colors rounded-lg min-h-[36px]',
                    isDropdownActive(entry.items)
                      ? 'text-primary-light bg-primary/10'
                      : 'text-text-muted hover:text-text-base hover:bg-text-base/5',
                  ]}
                  aria-expanded="false"
                  aria-haspopup="true"
                >
                  <span
                    data-i18n={
                      entry.label === 'Docs'
                        ? 'header.docs'
                        : entry.label === 'Blog'
                          ? 'header.blog'
                          : entry.label === 'Tools'
                            ? 'header.tools'
                            : 'header.community'
                    }
                  >
                    {entry.label}
                  </span>
                  <ChevronDown class="w-3.5 h-3.5 transition-transform duration-200" />
                </button>
                <div
                  class="nav-dropdown-menu absolute top-full left-0 mt-1.5 min-w-[220px] rounded-xl border border-border bg-bg-base/95 backdrop-blur-xl shadow-xl opacity-0 invisible translate-y-1 transition-all duration-200 z-50"
                  role="menu"
                >
                  <div class="py-1.5">
                    {entry.items.map((item) => (
                      <a
                        href={item.href}
                        role="menuitem"
                        tabindex="-1"
                        class:list={[
                          'block px-4 py-2.5 transition-colors',
                          isActive(item.href)
                            ? 'text-primary-light bg-primary/5'
                            : 'text-text-muted hover:text-text-base hover:bg-text-base/5',
                        ]}
                      >
                        <span
                          class="block text-sm font-medium"
                          data-i18n={
                            item.label === 'Stack Builder'
                              ? 'header.stack'
                              : item.label === 'Playground'
                                ? 'header.playground'
                                : item.label === 'Roadmap'
                                  ? 'header.roadmap'
                                  : item.label === 'Changelog'
                                    ? 'header.changelog'
                                    : item.label === 'Request a Chart'
                                      ? 'header.request'
                                      : 'header.community'
                          }
                        >
                          {item.label}
                        </span>
                        {item.description && (
                          <span class="block text-xs text-text-muted mt-0.5">{item.description}</span>
                        )}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={entry.href}
                class:list={[
                  'relative px-3 py-2 text-sm font-medium transition-colors rounded-lg min-h-[36px] inline-flex items-center',
                  isActive(entry.href)
                    ? 'text-primary-light bg-primary/10'
                    : 'text-text-muted hover:text-text-base hover:bg-text-base/5',
                ]}
              >
                <span data-i18n={entry.label === 'Docs' ? 'header.docs' : 'header.blog'}>{entry.label}</span>
              </a>
            ),
          )
        }

        <div class="h-5 w-px bg-border mx-1.5"></div>

        <button
          type="button"
          id="search-trigger"
          class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-text-muted transition-all hover:bg-text-base/5 hover:text-text-base min-h-[36px]"
          aria-label="Search documentation (Ctrl+K)"
          data-i18n-attr="aria-label"
          data-i18n-key="header.search"
        >
          <Search class="w-4 h-4" />
          <span
            class="text-xs text-text-muted hidden lg:inline-flex items-center gap-0.5 border border-border rounded-md px-1.5 py-0.5 font-mono"
          >
            <span class="text-[10px]" id="search-mod-key">Ctrl</span>K
          </span>
        </button>

        <LanguageSwitcher />

        <a
          href="https://github.com/helmforgedev/charts"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium text-text-muted transition-all hover:bg-text-base/5 hover:text-text-base min-h-[36px]"
        >
          <Github class="w-4 h-4" />
          <span class="hidden lg:inline" data-i18n="header.github">GitHub</span>
        </a>

        <div class="pl-1">
          <ThemeToggle />
        </div>
      </nav>

      <!-- Mobile controls -->
      <div class="flex items-center gap-2 md:hidden">
        <button
          type="button"
          id="search-trigger-mobile"
          class="flex items-center justify-center w-10 h-10 rounded-lg border border-border bg-bg-surface text-text-muted transition-colors hover:bg-text-base/5 hover:text-text-base"
          aria-label="Search documentation"
          data-i18n-attr="aria-label"
          data-i18n-key="header.mobile.search"
        >
          <Search class="w-4 h-4" />
        </button>
        <LanguageSwitcher />
        <ThemeToggle />

        <button
          type="button"
          id="mobile-menu-toggle"
          class="flex items-center justify-center w-10 h-10 rounded-lg border border-border bg-bg-surface text-text-muted transition-colors hover:bg-text-base/5 hover:text-text-base"
          aria-label="Toggle navigation menu"
          data-i18n-attr="aria-label"
          data-i18n-key="header.mobile.toggle"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <Menu id="menu-icon-open" class="w-5 h-5 absolute transition-all duration-300" />
          <X id="menu-icon-close" class="w-5 h-5 absolute opacity-0 scale-50 transition-all duration-300" />
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <nav
      id="mobile-menu"
      class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] md:hidden"
      aria-label="Mobile navigation"
    >
      <div class="overflow-hidden">
        <div class="flex flex-col gap-1 pb-4 pt-2">
          {
            mobileItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  'rounded-xl px-4 py-3 text-base font-medium transition-all min-h-[44px] flex items-center',
                  isActive(item.href)
                    ? 'bg-primary/10 text-primary-light border-l-4 border-primary'
                    : 'text-text-muted hover:bg-text-base/5 hover:text-text-base border-l-4 border-transparent',
                ]}
              >
                <span
                  data-i18n={
                    item.label === 'Docs'
                      ? 'header.docs'
                      : item.label === 'Blog'
                        ? 'header.blog'
                        : item.label === 'Stack Builder'
                          ? 'header.stack'
                          : item.label === 'Playground'
                            ? 'header.playground'
                            : item.label === 'Roadmap'
                              ? 'header.roadmap'
                              : item.label === 'Changelog'
                                ? 'header.changelog'
                                : item.label === 'Request a Chart'
                                  ? 'header.request'
                                  : 'header.community'
                  }
                >
                  {item.label}
                </span>
              </a>
            ))
          }
          <a
            href="https://github.com/helmforgedev/charts"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 rounded-xl px-4 py-3 text-base font-medium text-text-muted transition-all hover:bg-text-base/5 hover:text-text-base border-l-4 border-transparent min-h-[44px]"
          >
            <Github class="w-5 h-5" />
            <span data-i18n="header.github">GitHub</span>
          </a>
        </div>
      </div>
    </nav>
  </Container>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Search triggers
    const searchBtn = document.getElementById('search-trigger');
    const searchBtnMobile = document.getElementById('search-trigger-mobile');
    const modKey = document.getElementById('search-mod-key');

    if (modKey && navigator.platform?.includes('Mac')) {
      modKey.textContent = '\u2318';
    }

    function openSearch() {
      if (typeof (window as any).__openSearch === 'function') {
        (window as any).__openSearch();
      }
    }

    searchBtn?.addEventListener('click', openSearch);
    searchBtnMobile?.addEventListener('click', openSearch);

    // Dropdown menus
    const dropdowns = document.querySelectorAll('.nav-dropdown');

    dropdowns.forEach((dropdown) => {
      const trigger = dropdown.querySelector('.nav-dropdown-trigger') as HTMLButtonElement;
      const menu = dropdown.querySelector('.nav-dropdown-menu') as HTMLElement;
      const menuItems = menu.querySelectorAll<HTMLAnchorElement>('[role="menuitem"]');
      let timeout: ReturnType<typeof setTimeout>;

      function show() {
        clearTimeout(timeout);
        trigger.setAttribute('aria-expanded', 'true');
        menu.classList.remove('opacity-0', 'invisible', 'translate-y-1');
        menu.classList.add('opacity-100', 'visible', 'translate-y-0');
        const chevron = trigger.querySelector('svg:last-child');
        if (chevron) (chevron as HTMLElement).style.transform = 'rotate(180deg)';
      }

      function hide() {
        timeout = setTimeout(() => {
          trigger.setAttribute('aria-expanded', 'false');
          menu.classList.add('opacity-0', 'invisible', 'translate-y-1');
          menu.classList.remove('opacity-100', 'visible', 'translate-y-0');
          const chevron = trigger.querySelector('svg:last-child');
          if (chevron) (chevron as HTMLElement).style.transform = '';
        }, 150);
      }

      dropdown.addEventListener('mouseenter', show);
      dropdown.addEventListener('mouseleave', hide);
      trigger.addEventListener('click', () => {
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        isOpen ? hide() : show();
      });
      trigger.addEventListener('focus', show);
      menu.addEventListener('mouseenter', () => clearTimeout(timeout));

      // Keyboard navigation within dropdown
      trigger.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown' || e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          show();
          setTimeout(() => {
            const items = menu.querySelectorAll<HTMLAnchorElement>('[role="menuitem"]');
            if (items[0]) {
              items[0].focus();
              // WebKit sometimes needs a second attempt
              if (document.activeElement !== items[0]) {
                items[0].focus();
              }
            }
          }, 150);
        }
      });

      menuItems.forEach((item, i) => {
        item.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            menuItems[Math.min(i + 1, menuItems.length - 1)]?.focus();
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (i === 0) {
              trigger.focus();
              hide();
            } else {
              menuItems[i - 1]?.focus();
            }
          } else if (e.key === 'Escape') {
            e.preventDefault();
            hide();
            trigger.focus();
          } else if (e.key === 'Tab') {
            hide();
          }
        });
      });
    });

    // Close dropdowns on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdowns.forEach((dropdown) => {
          const trigger = dropdown.querySelector('.nav-dropdown-trigger') as HTMLButtonElement;
          const menu = dropdown.querySelector('.nav-dropdown-menu') as HTMLElement;
          trigger.setAttribute('aria-expanded', 'false');
          menu.classList.add('opacity-0', 'invisible', 'translate-y-1');
          menu.classList.remove('opacity-100', 'visible', 'translate-y-0');
        });
      }
    });

    // Mobile menu
    const toggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    function closeMenu() {
      mobileMenu.style.gridTemplateRows = '0fr';
      iconOpen.style.opacity = '1';
      iconOpen.style.transform = 'scale(1)';
      iconClose.style.opacity = '0';
      iconClose.style.transform = 'scale(0.5)';
      toggle.setAttribute('aria-expanded', 'false');
    }

    function openMenu() {
      mobileMenu.style.gridTemplateRows = '1fr';
      iconOpen.style.opacity = '0';
      iconOpen.style.transform = 'scale(0.5)';
      iconClose.style.opacity = '1';
      iconClose.style.transform = 'scale(1)';
      toggle.setAttribute('aria-expanded', 'true');
    }

    if (toggle && mobileMenu && iconOpen && iconClose) {
      toggle.addEventListener('click', () => {
        const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
        isExpanded ? closeMenu() : openMenu();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
          closeMenu();
          toggle.focus();
        }
      });
    }
  });
</script>
