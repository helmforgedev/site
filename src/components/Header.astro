---
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Docs', href: '/docs' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="glass-panel sticky top-0 z-50 border-b border-border shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center group text-text-base transition-colors" aria-label="HelmForge home">
                <svg class="h-9 sm:h-10 w-auto transition-transform group-hover:scale-105" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 350 100" fill="none">
          <g>
            <defs>
              <linearGradient id="logo-m1" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#a78bfa" />
                <stop offset="100%" stop-color="#6d28d9" />
              </linearGradient>
              <linearGradient id="logo-m2" x1="0%" y1="100%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#fb923c" />
                <stop offset="100%" stop-color="#c2410c" />
              </linearGradient>
              <linearGradient id="logo-m3" x1="0%" y1="50%" x2="100%" y2="50%">
                <stop offset="0%" stop-color="#8b5cf6" />
                <stop offset="50%" stop-color="#f43f5e" />
                <stop offset="100%" stop-color="#f97316" />
              </linearGradient>
            </defs>
            <polygon points="25,15 45,15 35,85 15,85" fill="url(#logo-m1)" />
            <polygon points="65,15 85,15 75,85 55,85" fill="url(#logo-m2)" />
            <polygon points="28,45 72,45 68,55 24,55" fill="url(#logo-m3)" />
          </g>
          <text x="110" y="66" font-family="'Outfit', system-ui, sans-serif" font-size="46" font-weight="700" fill="currentColor">
            Helm<tspan fill="#f97316">Forge</tspan>
          </text>
        </svg>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'rounded-full px-4 py-2 text-sm font-medium transition-colors',
              isActive(item.href)
                ? 'bg-primary/20 text-primary-light'
                : 'text-text-muted hover:bg-text-base/5 hover:text-text-base',
            ]}
          >
            {item.label}
          </a>
        ))}
        <a
          href="https://github.com/helmforgedev/charts"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 rounded-full px-4 py-2 text-sm font-medium text-text-muted transition-colors hover:bg-text-base/5 hover:text-text-base"
        >
          GitHub
          <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
        <div class="pl-2 border-l border-border ml-1">
          <ThemeToggle />
        </div>
      </nav>

      <!-- Mobile controls -->
      <div class="flex items-center gap-2 md:hidden">
        <ThemeToggle />
        
        <button
          id="mobile-menu-toggle"
          class="rounded-full border border-border bg-bg-surface p-2 text-text-muted transition-colors hover:bg-text-base/5 hover:text-text-base"
          aria-label="Toggle navigation menu"
        >
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <nav id="mobile-menu" class="mt-3 hidden rounded-2xl glass-panel p-3 md:hidden">
      <div class="flex flex-col gap-1">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'rounded-xl px-3 py-2 text-sm font-medium transition-colors',
              isActive(item.href)
                ? 'bg-primary text-white'
                : 'text-text-muted hover:bg-text-base/5 hover:text-text-base',
            ]}
          >
            {item.label}
          </a>
        ))}
        <a
          href="https://github.com/helmforgedev/charts"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 rounded-xl px-3 py-2 text-sm font-medium text-text-muted transition-colors hover:bg-text-base/5 hover:text-text-base"
        >
          GitHub
          <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (() => {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    if (toggle && menu && iconOpen && iconClose) {
      toggle.addEventListener('click', () => {
        menu.classList.toggle('hidden');
        iconOpen.classList.toggle('hidden');
        iconClose.classList.toggle('hidden');
      });
    }
  })();
</script>

