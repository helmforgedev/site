---
import { LOCALE_FLAGS, LOCALE_LABELS, SUPPORTED_LOCALES } from '../i18n/config';
---

<div class="relative" data-locale-switcher>
  <button
    type="button"
    data-locale-button
    aria-label="Select language"
    aria-haspopup="menu"
    aria-expanded="false"
    class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-bg-surface px-2 py-1.5 text-xs font-semibold text-text-muted transition-colors hover:bg-text-base/5 hover:text-text-base min-h-[36px]"
  >
    <span data-locale-current-flag>{LOCALE_FLAGS.en}</span>
    <span data-locale-current-label class="hidden sm:inline">{LOCALE_LABELS.en}</span>
  </button>

  <div
    data-locale-menu
    class="hidden absolute right-0 top-full mt-1 min-w-[150px] rounded-xl border border-border bg-bg-base/95 p-1 shadow-xl backdrop-blur-xl z-50"
    role="menu"
  >
    {
      SUPPORTED_LOCALES.map((locale) => (
        <button
          type="button"
          data-locale-option
          data-locale={locale}
          class="flex w-full items-center gap-2 rounded-lg px-2.5 py-2 text-left text-sm text-text-muted transition-colors hover:bg-text-base/5 hover:text-text-base"
          role="menuitem"
        >
          <span>{LOCALE_FLAGS[locale]}</span>
          <span>{LOCALE_LABELS[locale]}</span>
        </button>
      ))
    }
  </div>
</div>
