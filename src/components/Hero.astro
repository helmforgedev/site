<section class="relative overflow-hidden py-20 sm:py-28 lg:py-32">
  <div class="absolute inset-x-0 top-0 h-px bg-white/10"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--color-primary-dark),_transparent_40%)] opacity-30"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_var(--color-accent),_transparent_40%)] opacity-20"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold tracking-[0.2em] uppercase text-primary-light mb-4">
        Production-ready Helm charts
      </p>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight leading-tight heading-font text-text-base">
        Open-source Helm charts, <span class="bg-gradient-to-r from-primary-light to-accent bg-clip-text text-transparent">forged to last.</span>
      </h1>

      <p class="mt-8 text-lg text-text-muted leading-relaxed max-w-xl">
        The ultimate open-source alternative to Bitnami. We package popular applications with sane defaults for security, built-in S3 backups, and day-two operations. No proprietary layers. No limits.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center gap-4">
        <a
          href="/docs/getting-started"
          class="glow-effect inline-flex w-full items-center justify-center rounded-xl bg-primary px-8 py-4 text-base font-bold text-white transition-all hover:scale-[1.02] sm:w-auto"
        >
          Start Forging
        </a>
        <a
          href="/docs/charts"
          class="glass-panel inline-flex w-full items-center justify-center rounded-xl px-8 py-4 text-base font-bold text-text-base transition-all hover:bg-text-base/5 sm:w-auto"
        >
          Browse Registry
        </a>
      </div>
    </div>

    <!-- Terminal Mockup -->
    <div class="w-full max-w-[500px] mx-auto lg:max-w-none relative group" style="perspective: 1000px;">
      <div class="absolute -inset-1.5 rounded-2xl bg-gradient-to-tr from-primary to-accent opacity-40 blur-2xl group-hover:opacity-60 transition duration-1000"></div>
      
      <div 
        class="relative hover:-translate-y-1 hover:rotate-1 rounded-2xl overflow-hidden shadow-2xl border border-white/10 bg-slate-950/90 backdrop-blur-xl transition-transform duration-500 ease-in-out"
        style="transform: rotateY(-5deg) rotateX(2deg);"
      >
        <!-- Mac Header -->
        <div class="flex items-center px-4 py-3 border-b border-border bg-bg-surface/50">
          <div class="flex space-x-2">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
          </div>
          <div class="mx-auto text-xs text-text-muted font-mono pr-8">bash - devops@helmforge</div>
        </div>
        <!-- Terminal Body -->
        <div class="p-5 font-mono text-sm leading-relaxed h-[300px] overflow-y-auto text-slate-200">
          <div class="text-green-400 mb-2 font-bold">➜  ~ <span class="text-slate-200 font-normal">kubernetes cluster ready</span></div>
          <div class="text-green-400 font-bold">➜  ~ <span id="typed-element" class="text-slate-200 font-normal"></span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import Typed from 'typed.js';

  document.addEventListener('DOMContentLoaded', () => {
    // We use Typed.js to simulate a clean helm installation flow
    const options = {
      strings: [
        'kubectl apply -f ./postgresql-manifests/^200\n<br><span class="text-red-500 font-bold">Error from server CrashLoopBackOff</span>^2000',
        'helm repo add helmforge https://repo.helmforge.dev^500\n<br><span class="text-blue-300">"helmforge" has been added to your repositories</span>^1500',
        'helm install db helmforge/postgresql^500\n<br><br><span class="text-green-400 font-bold">SUCCESS!</span><br><span class="text-blue-300">✓ PostgreSQL deployed with secure boundaries</span><br><span class="text-blue-300">✓ Built-in S3 Backup cronjob configured</span><br><span class="text-blue-300">✓ Automatic TLS certificates attached</span><br><br><span class="text-white">Happy forging!</span>^5000'
      ],
      typeSpeed: 45,
      backSpeed: 20,
      backDelay: 1000,
      loop: true,
      showCursor: true,
      cursorChar: '█',
      contentType: 'html'
    };

    if (document.getElementById('typed-element')) {
      new Typed('#typed-element', options);
    }
  });
</script>
