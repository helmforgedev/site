---
import { Terminal, Database } from 'lucide-astro';
import Container from './Container.astro';
---

<section class="relative overflow-hidden py-24 sm:py-32 lg:pb-40 lg:pt-36">
  <!-- Subtle Grid Background -->
  <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjQiIGhlaWdodD0iMjQiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PHBhdGggZD0iTTAgMGgyNHYyNEgwem0xIDF2MjJoMjJWMXoiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wMSkiIGZpbGwtcnVsZT0iZXZlbm9kZCIvPjwvc3ZnPg==')] [mask-image:linear-gradient(to_bottom,white,transparent)]"></div>

  <!-- Animated Mesh Gradients -->
  <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-[800px] h-[600px] bg-primary/20 rounded-full blur-[120px] opacity-50 mix-blend-screen pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/3 w-[600px] h-[600px] bg-accent/15 rounded-full blur-[100px] opacity-40 mix-blend-screen pointer-events-none"></div>

  <Container class="relative grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-8 items-center">
    
    <!-- Left Copy -->
    <div class="lg:col-span-6 flex flex-col justify-center text-center lg:text-left">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary-light text-xs font-bold tracking-wider uppercase w-fit mx-auto lg:mx-0 mb-8 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-light opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
        </span>
        Production-Ready
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight leading-tight heading-font text-text-base">
        Open-source Helm charts, <span class="bg-gradient-to-r from-primary-light to-accent bg-clip-text text-transparent">forged to last.</span>
      </h1>

      <p class="mt-6 text-lg text-text-muted leading-relaxed max-w-2xl mx-auto lg:mx-0">
        The ultimate open-source alternative to legacy registries. We package applications with sane security defaults, built-in backups, and day-two operations natively integrated.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start">
        <a
          href="/docs/getting-started"
          class="glow-effect group inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-2xl bg-primary px-8 py-4 text-base font-bold text-white transition-all hover:-translate-y-1 hover:shadow-2xl hover:shadow-primary/30"
        >
          <Terminal class="w-5 h-5 transition-transform group-hover:scale-110" />
          Start Forging
        </a>
        <a
          href="/docs/charts"
          class="glass-panel group inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-2xl px-8 py-4 text-base font-bold text-text-base transition-all hover:bg-text-base/10 hover:-translate-y-1 hover:shadow-xl"
        >
          <Database class="w-5 h-5 text-text-muted transition-colors group-hover:text-primary-light" />
          Browse Registry
        </a>
      </div>
    </div>

    <!-- Right Terminal Mockup -->
    <div class="lg:col-span-6 w-full max-w-xl mx-auto lg:max-w-none relative perspective-[2000px]">
      <div class="absolute -inset-2 rounded-[2rem] bg-gradient-to-br from-primary-light/30 via-accent/20 to-transparent opacity-60 blur-2xl"></div>
      
      <div 
        class="relative rounded-2xl overflow-hidden shadow-2xl border border-white/10 bg-black/80 backdrop-blur-2xl transition-all duration-700 ease-out hover:rotate-0 hover:scale-[1.02]"
        style="transform: rotateY(-8deg) rotateX(4deg);"
      >
        <!-- macOS Style Header -->
        <div class="flex items-center px-4 py-3 border-b border-white/5 bg-white/5">
          <div class="flex space-x-2">
            <div class="w-3 h-3 rounded-full bg-[#ff5f56] border border-[#e0443e]"></div>
            <div class="w-3 h-3 rounded-full bg-[#ffbd2e] border border-[#dea123]"></div>
            <div class="w-3 h-3 rounded-full bg-[#27c93f] border border-[#1aab29]"></div>
          </div>
          <div class="mx-auto text-xs text-text-muted/70 font-mono tracking-wider flex border border-white/5 rounded-md px-2 py-0.5 bg-black/30">
            <Terminal class="w-3 h-3 mr-2 opacity-50" />
            helmforge — bash
          </div>
        </div>
        
        <!-- Terminal Body -->
        <div class="p-6 font-mono text-sm leading-relaxed h-[320px] overflow-y-auto scrollbar-hide text-zinc-300">
          <div class="flex items-center text-primary-light mb-2 font-bold cursor-default">
            <span class="mr-2">❯</span>
            <span class="text-white/60 font-normal">kubernetes cluster ready</span>
          </div>
          <div class="flex items-start font-bold cursor-default">
            <span class="text-primary-light mr-2 mt-0.5">❯</span>
            <span id="typed-element" class="text-white font-normal break-words whitespace-pre-wrap"></span>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  import Typed from 'typed.js';

  document.addEventListener('DOMContentLoaded', () => {
    const options = {
      strings: [
        'helm repo add helmforge https://repo.helmforge.dev^500\n<br><span class="text-zinc-500">"helmforge" has been added to your repositories</span>^1000',
        'helm install db helmforge/postgresql^500\n<br><br><span class="text-emerald-400 font-bold">SUCCESS!</span>\n<span class="text-zinc-400">✓ PostgreSQL deployed with secure boundaries</span>\n<span class="text-zinc-400">✓ Built-in S3 Backup cronjob configured</span>\n<span class="text-zinc-400">✓ Automatic TLS certificates attached</span><br><br><span class="text-white font-semibold flex items-center gap-2">🚀 Happy forging!</span>^5000'
      ],
      typeSpeed: 30,
      backSpeed: 15,
      backDelay: 1500,
      loop: true,
      showCursor: true,
      cursorChar: '<span class="animate-pulse text-primary-light">|</span>',
      contentType: 'html'
    };

    if (document.getElementById('typed-element')) {
      new Typed('#typed-element', options);
    }
  });
</script>
