const maturityStyles = {
  stable: 'bg-emerald-50 text-emerald-700 border-emerald-200',
  beta: 'bg-amber-50 text-amber-700 border-amber-200',
  alpha: 'bg-rose-50 text-rose-700 border-rose-200',
} as const;

const chartCount = charts.length;
const backupCount = charts.filter((chart) => chart.backup).length;
const stableCount = charts.filter((chart) => chart.maturity === 'stable').length;
---

<section class="bg-surface py-16 sm:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <p class="text-sm font-medium uppercase tracking-[0.18em] text-primary">Charts</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-dark">
          A cleaner catalog for common Kubernetes workloads.
        </h2>
        <p class="mt-4 text-base sm:text-lg leading-relaxed text-muted">
          Browse application charts with consistent structure, documented values, and production-minded defaults.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-3 sm:gap-4 lg:min-w-[320px]">
        <div class="rounded-2xl border border-slate-200 bg-white px-4 py-4">
          <p class="text-2xl font-semibold tracking-tight text-dark">{chartCount}</p>
          <p class="mt-1 text-xs uppercase tracking-[0.16em] text-muted">Charts</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white px-4 py-4">
          <p class="text-2xl font-semibold tracking-tight text-dark">{stableCount}</p>
          <p class="mt-1 text-xs uppercase tracking-[0.16em] text-muted">Stable</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white px-4 py-4">
          <p class="text-2xl font-semibold tracking-tight text-dark">{backupCount}</p>
          <p class="mt-1 text-xs uppercase tracking-[0.16em] text-muted">With S3</p>
        </div>
      </div>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
      {charts.map((chart) => (
        <a
          href={`/docs/charts/${chart.slug}`}
          class="group rounded-2xl border border-slate-200 bg-white p-5 transition-all hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-sm"
        >
          <div class="flex items-start justify-between gap-3">
            <div class="flex items-center gap-3 min-w-0">
              <div class={`flex h-11 w-11 shrink-0 items-center justify-center rounded-xl text-sm font-semibold ${chart.color}`}>
                {chart.letter}
              </div>
              <div class="min-w-0">
                <h3 class="truncate text-base font-semibold text-dark transition-colors group-hover:text-primary">
                  {chart.name}
                </h3>
                <div class="mt-2 flex flex-wrap items-center gap-2">
                  <span class={`inline-flex rounded-full border px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.16em] ${maturityStyles[chart.maturity]}`}>
                    {chart.maturity}
                  </span>
                  {chart.backup && (
                    <span class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.16em] text-sky-700">
                      S3 backup
                    </span>
                  )}
                </div>
              </div>
            </div>

            <svg class="mt-1 h-4 w-4 shrink-0 text-slate-300 transition-transform group-hover:translate-x-0.5 group-hover:text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>

          <p class="mt-4 text-sm leading-6 text-muted">
            {chart.description}
          </p>
        </a>
      ))}
    </div>
  </div>
</section>
