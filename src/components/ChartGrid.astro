---
import { Search } from 'lucide-astro';
import Container from './Container.astro';
import SectionHeader from './SectionHeader.astro';
import Badge from './Badge.astro';
import { charts, chartCount, backupCount, stableCount, slugColor, chartIcon, FALLBACK_ICON } from '../data/charts';
---

<section class="py-16 sm:py-20 relative">
  <Container>
    <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <SectionHeader
          label="Catalog"
          title="A cleaner catalog for common Kubernetes workloads."
          description="Browse application charts with consistent structure, documented values, and production-minded defaults."
        />

        <!-- Search Input -->
        <div class="mt-8 relative max-w-md group focus-within:ring-0">
          <label for="chart-search" class="sr-only">Search charts</label>
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <Search class="h-5 w-5 text-text-muted transition-colors group-focus-within:text-primary-light" />
          </div>
          <input
            type="search"
            id="chart-search"
            class="block w-full pl-12 pr-4 py-3.5 border border-border rounded-2xl leading-5 bg-bg-surface/80 backdrop-blur-sm text-text-base placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary-light focus:border-transparent transition-all sm:text-sm hover:border-border/80 shadow-sm"
            placeholder="Search charts (e.g. postgres, redis, backup)..."
          />
          <div id="chart-search-status" class="sr-only" aria-live="polite" role="status"></div>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-3 sm:gap-4 lg:min-w-[320px] mt-8 lg:mt-0">
        <div class="glass-panel rounded-2xl px-4 py-4 text-center">
          <p class="text-3xl font-bold tracking-tight text-text-base">{chartCount}</p>
          <p class="mt-1 text-xs uppercase tracking-[0.16em] text-text-muted">Charts</p>
        </div>
        <div class="glass-panel rounded-2xl px-4 py-4 text-center">
          <p class="text-3xl font-bold tracking-tight text-text-base">{stableCount}</p>
          <p class="mt-1 text-xs uppercase tracking-[0.16em] text-text-muted">Stable</p>
        </div>
        <div class="glass-panel rounded-2xl px-4 py-4 text-center">
          <p class="text-3xl font-bold tracking-tight text-text-base">{backupCount}</p>
          <p class="mt-1 text-xs uppercase tracking-[0.16em] text-text-muted">With S3</p>
        </div>
      </div>
    </div>

    <!-- Empty State -->
    <div
      id="chart-empty-state"
      class="hidden mt-12 glass-panel rounded-2xl py-16 text-center border-dashed border-border border-2"
    >
      <svg class="mx-auto h-12 w-12 text-text-muted/50 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <div class="text-lg font-bold text-text-base">No charts found</div>
      <p class="mt-2 text-text-muted">Try adjusting your search terms.</p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" id="chart-grid-container">
      {
        charts.map((chart) => (
          <a
            href={`/docs/charts/${chart.slug}`}
            class="chart-card group relative rounded-3xl border border-border bg-bg-surface/40 p-5 transition-all duration-400 hover:-translate-y-1 hover:border-primary/40 hover:bg-bg-surface/80 hover:shadow-xl hover:shadow-primary/10 overflow-hidden flex flex-col h-full"
            data-name={chart.name.toLowerCase()}
            data-desc={chart.description.toLowerCase()}
          >
            <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100 pointer-events-none" />

            <div class="relative flex items-start justify-between gap-3">
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <div
                  class={`flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl text-sm font-bold shadow-inner ${slugColor(chart.slug)} opacity-90 group-hover:opacity-100 transition-all duration-300 group-hover:scale-110 backdrop-blur-md border border-white/10 overflow-hidden`}
                >
                  <img
                    src={chartIcon(chart.slug)}
                    alt={`${chart.name} icon`}
                    class="w-6 h-6 object-contain drop-shadow-md"
                    loading="lazy"
                    decoding="async"
                    width="24"
                    height="24"
                    onerror={`this.onerror=null;this.src='${FALLBACK_ICON}'`}
                  />
                </div>
                <div class="min-w-0 flex-1 pr-1">
                  <div
                    class="truncate text-base font-bold text-text-base transition-colors group-hover:text-primary-light"
                    title={chart.name}
                  >
                    {chart.name}
                  </div>
                  <div class="flex flex-wrap items-center gap-1.5 mt-1">
                    <Badge variant={chart.maturity} />
                    {chart.backup && <Badge variant="feature" label="S3 backup" />}
                  </div>
                </div>
              </div>

              <svg
                class="mt-0.5 h-4 w-4 shrink-0 text-text-muted transition-transform group-hover:translate-x-1 group-hover:text-primary-light"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>

            <p class="mt-3.5 text-xs leading-relaxed line-clamp-2 text-text-muted flex-grow">{chart.description}</p>
          </a>
        ))
      }
    </div>

    <!-- Request CTA -->
    <div class="mt-10 flex justify-center">
      <a
        href="/request"
        class="group inline-flex items-center gap-2 rounded-full border border-border bg-bg-surface px-6 py-3 text-sm font-semibold text-text-base transition-all hover:border-primary/50 hover:text-primary-light hover:shadow-lg hover:shadow-primary/10"
      >
        Don't see your app? Request a chart
        <svg
          class="w-4 h-4 transition-transform group-hover:translate-x-1"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"
          ></path></svg
        >
      </a>
    </div>
  </Container>
</section>

<script>
  import '../scripts/chart-search';
</script>
