---
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  caption?: string;
}

const { src, alt, width = 1600, height = 900, caption } = Astro.props;
---

<figure class="mb-8">
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading="eager"
    class="w-full rounded-2xl border border-border object-cover aspect-[16/9]"
  />
  {caption && <figcaption class="mt-2 text-sm text-text-muted">{caption}</figcaption>}
</figure>
