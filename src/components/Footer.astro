---
const year = new Date().getFullYear();
---

<footer class="bg-slate-900 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center mb-3">
          <img src="/helmforge-logo-horizontal.png" alt="HelmForge" class="h-10 w-auto" />
        </a>
        <p class="text-sm leading-relaxed text-slate-400">
          Forged with care for the Kubernetes community.
        </p>
      </div>

      <!-- Documentation -->
      <div>
        <h3 class="text-sm font-semibold text-slate-200 uppercase tracking-wider mb-3">Documentation</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/docs/getting-started" class="text-slate-400 hover:text-white transition-colors">Getting Started</a></li>
          <li><a href="/docs/charts" class="text-slate-400 hover:text-white transition-colors">Charts</a></li>
          <li><a href="/docs" class="text-slate-400 hover:text-white transition-colors">Docs Overview</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h3 class="text-sm font-semibold text-slate-200 uppercase tracking-wider mb-3">Community</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="https://github.com/helmforgedev/charts" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors">
              GitHub
            </a>
          </li>
          <li>
            <a href="https://repo.helmforge.dev" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors">
              Helm Repository
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-slate-700/50 text-sm text-center text-slate-500">
      <p>&copy; {year} HelmForge. All rights reserved.</p>
    </div>
  </div>
</footer>
