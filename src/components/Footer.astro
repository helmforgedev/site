---
const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-border bg-bg-surface/50">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-[minmax(0,1.25fr)_1fr_1fr]">
      <!-- Brand -->
      <div>
        <a href="/" class="mb-4 inline-flex items-center text-text-base transition-colors group" aria-label="HelmForge home">
                  <svg class="h-10 w-auto transition-transform group-hover:scale-105" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 350 100" fill="none">
            <g>
              <defs>
                <linearGradient id="logo-foot-m1" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#a78bfa" />
                  <stop offset="100%" stop-color="#6d28d9" />
                </linearGradient>
                <linearGradient id="logo-foot-m2" x1="0%" y1="100%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#fb923c" />
                  <stop offset="100%" stop-color="#c2410c" />
                </linearGradient>
                <linearGradient id="logo-foot-m3" x1="0%" y1="50%" x2="100%" y2="50%">
                  <stop offset="0%" stop-color="#8b5cf6" />
                  <stop offset="50%" stop-color="#f43f5e" />
                  <stop offset="100%" stop-color="#f97316" />
                </linearGradient>
              </defs>
              <polygon points="25,15 45,15 35,85 15,85" fill="url(#logo-foot-m1)" />
              <polygon points="65,15 85,15 75,85 55,85" fill="url(#logo-foot-m2)" />
              <polygon points="28,45 72,45 68,55 24,55" fill="url(#logo-foot-m3)" />
            </g>
          <text x="110" y="66" font-family="'Outfit', system-ui, sans-serif" font-size="46" font-weight="700" fill="currentColor">
            Helm<tspan fill="#f97316">Forge</tspan>
          </text>
        </a>
        <p class="mt-4 text-sm text-text-muted leading-relaxed max-w-sm">
          Open-source Helm charts with practical defaults for real Kubernetes operations.
        </p>
      </div>

      <!-- Documentation -->
      <div>
        <div class="mb-3 text-[11px] font-bold uppercase tracking-[0.18em] text-text-base">Documentation</div>
        <ul class="space-y-2 text-sm">
          <li><a href="/docs/getting-started" class="text-text-muted transition-colors hover:text-text-base">Getting Started</a></li>
          <li><a href="/docs/charts" class="text-text-muted transition-colors hover:text-text-base">Charts</a></li>
          <li><a href="/docs" class="text-text-muted transition-colors hover:text-text-base">Docs Overview</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <div class="mb-3 text-[11px] font-bold uppercase tracking-[0.18em] text-text-base">Community</div>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="https://github.com/helmforgedev/charts" target="_blank" rel="noopener noreferrer" class="text-text-muted transition-colors hover:text-text-base">
              GitHub
            </a>
          </li>
          <li>
            <a href="https://repo.helmforge.dev" target="_blank" rel="noopener noreferrer" class="text-text-muted transition-colors hover:text-text-base">
              Helm Repository
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-8 border-t border-border pt-6 text-center text-sm text-text-muted/60">
      <p>&copy; {year} HelmForge.</p>
    </div>
  </div>
</footer>

