---
import Logo from './Logo.astro';
import Container from './Container.astro';

const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-border bg-bg-surface/50">
  <Container class="py-10">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-[minmax(0,1.25fr)_1fr_1fr]">
      <!-- Brand -->
      <div>
        <a
          href="/"
          class="mb-4 inline-flex items-center text-text-base transition-colors group"
          aria-label="HelmForge home"
          data-i18n-attr="aria-label"
          data-i18n-key="header.home"
        >
          <Logo variant="horizontal" class="h-10 w-auto transition-transform group-hover:scale-105" />
        </a>
        <p class="mt-4 text-sm text-text-muted leading-relaxed max-w-sm">
          <span data-i18n="footer.tagline"
            >Open-source Helm charts with practical defaults for real Kubernetes operations.</span
          >
        </p>
      </div>

      <!-- Documentation -->
      <div>
        <div class="mb-3 text-[11px] font-bold uppercase tracking-[0.18em] text-text-base" data-i18n="footer.docs">
          Documentation
        </div>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/docs/getting-started" class="text-text-muted transition-colors hover:text-text-base"
              ><span data-i18n="footer.gettingStarted">Getting Started</span></a
            >
          </li>
          <li>
            <a href="/docs/charts" class="text-text-muted transition-colors hover:text-text-base"
              ><span data-i18n="footer.charts">Charts</span></a
            >
          </li>
          <li>
            <a href="/docs" class="text-text-muted transition-colors hover:text-text-base"
              ><span data-i18n="footer.docsOverview">Docs Overview</span></a
            >
          </li>
          <li>
            <a href="/stack" class="text-text-muted transition-colors hover:text-text-base"
              ><span data-i18n="footer.stackBuilder">Stack Builder</span></a
            >
          </li>
          <li>
            <a href="/playground" class="text-text-muted transition-colors hover:text-text-base"
              ><span data-i18n="footer.playground">Values Playground</span></a
            >
          </li>
          <li>
            <a
              href="/changelog"
              class="text-text-muted transition-colors hover:text-text-base"
              data-i18n="header.changelog">Changelog</a
            >
          </li>
          <li>
            <a href="/blog" class="text-text-muted transition-colors hover:text-text-base" data-i18n="header.blog"
              >Blog</a
            >
          </li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <div class="mb-3 text-[11px] font-bold uppercase tracking-[0.18em] text-text-base" data-i18n="footer.community">
          Community
        </div>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="/community"
              class="text-text-muted transition-colors hover:text-text-base"
              data-i18n="footer.community">Community</a
            >
          </li>
          <li>
            <a href="/roadmap" class="text-text-muted transition-colors hover:text-text-base" data-i18n="header.roadmap"
              >Roadmap</a
            >
          </li>
          <li>
            <a
              href="https://github.com/helmforgedev/charts"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted transition-colors hover:text-text-base"
            >
              GitHub
            </a>
          </li>
          <li>
            <a
              href="https://repo.helmforge.dev"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-muted transition-colors hover:text-text-base"
            >
              <span data-i18n="footer.helmRepo">Helm Repository</span>
            </a>
          </li>
          <li>
            <a href="/rss.xml" class="text-text-muted transition-colors hover:text-text-base">
              <span data-i18n="footer.rss">RSS Feed</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-8 border-t border-border pt-6 text-center text-sm text-text-muted">
      <p>&copy; {year} HelmForge.</p>
    </div>
  </Container>
</footer>
