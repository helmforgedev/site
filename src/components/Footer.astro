---
const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-slate-200 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-[minmax(0,1.25fr)_1fr_1fr]">
      <!-- Brand -->
      <div>
        <a href="/" class="mb-3 flex items-center gap-3">
          <img src="/favicon.svg" alt="" class="h-10 w-10 rounded-xl shadow-sm" />
          <span class="text-xl font-semibold tracking-tight text-dark">
            Helm<span class="text-primary">Forge</span>
          </span>
        </a>
        <p class="max-w-sm text-sm leading-relaxed text-slate-500">
          Open-source Helm charts with practical defaults for real Kubernetes operations.
        </p>
      </div>

      <!-- Documentation -->
      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Documentation</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/docs/getting-started" class="text-slate-600 transition-colors hover:text-dark">Getting Started</a></li>
          <li><a href="/docs/charts" class="text-slate-600 transition-colors hover:text-dark">Charts</a></li>
          <li><a href="/docs" class="text-slate-600 transition-colors hover:text-dark">Docs Overview</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Community</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="https://github.com/helmforgedev/charts" target="_blank" rel="noopener noreferrer" class="text-slate-600 transition-colors hover:text-dark">
              GitHub
            </a>
          </li>
          <li>
            <a href="https://repo.helmforge.dev" target="_blank" rel="noopener noreferrer" class="text-slate-600 transition-colors hover:text-dark">
              Helm Repository
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-8 border-t border-slate-200 pt-6 text-center text-sm text-slate-400">
      <p>&copy; {year} HelmForge.</p>
    </div>
  </div>
</footer>
