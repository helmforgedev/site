        <text x="235" y="256" text-anchor="middle" fill="currentColor" class="diagram-text">
          NetworkPolicy
        </text>
        <text x="235" y="271" text-anchor="middle" fill="currentColor" class="diagram-label muted">
          ingress/egress
        </text>

        <rect
          x="540"
          y="304"
          width="150"
          height="42"
          rx="8"
          fill="currentColor"
          fill-opacity="0.04"
