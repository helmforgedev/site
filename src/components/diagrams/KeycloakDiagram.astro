        <text x="615" y="329" text-anchor="middle" fill="currentColor" class="diagram-text">
          S3 backup
        </text>

        <line x1="615" y1="276" x2="615" y2="304" stroke="currentColor" stroke-width="1.2" stroke-dasharray="4 3" />
