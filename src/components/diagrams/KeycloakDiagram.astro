          Keycloak pod
        </text>
        <text x="615" y="60" text-anchor="middle" fill="currentColor" class="diagram-label muted">
          replica 1
        </text>

        <rect
          x="540"
          y="118"
          width="150"
          height="64"
          rx="8"
          fill="currentColor"
          fill-opacity="0.08"
          stroke="currentColor"
          stroke-width="1.5"
        />
        <text x="615" y="143" text-anchor="middle" fill="currentColor" class="diagram-text" font-weight="bold">
          Keycloak pod
        </text>
        <text x="615" y="158" text-anchor="middle" fill="currentColor" class="diagram-label muted">
          replica n
        </text>

        <line x1="615" y1="84" x2="615" y2="118" stroke="currentColor" stroke-width="1" stroke-dasharray="4 3" />
        <text x="635" y="104" fill="currentColor" class="diagram-label muted">
          JDBC_PING/cache
        </text>

        <rect
          x="360"
          y="190"
          width="120"
          height="54"
          rx="8"
          fill="currentColor"
          fill-opacity="0.04"
          stroke="currentColor"
          stroke-width="1.5"
        />
        <text x="420" y="212" text-anchor="middle" fill="currentColor" class="diagram-text">
          Management
        </text>
        <text x="420" y="227" text-anchor="middle" fill="currentColor" class="diagram-label muted">
          private :9000
        </text>

        <rect
          x="540"
          y="222"
          width="150"
          height="54"
          rx="8"
          fill="currentColor"
          fill-opacity="0.05"
          stroke="currentColor"
          stroke-width="1.5"
        />
        <text x="615" y="244" text-anchor="middle" fill="currentColor" class="diagram-text">
          PostgreSQL
        </text>
        <text x="615" y="259" text-anchor="middle" fill="currentColor" class="diagram-label muted">
          shared state
        </text>

        <line x1="615" y1="182" x2="615" y2="222" stroke="currentColor" stroke-width="1.5" />
        <polygon points="610,212 615,222 620,212" fill="currentColor" />

        <rect
          x="172"
          y="234"
          width="126"
          height="54"
          rx="8"
          fill="currentColor"
          fill-opacity="0.04"
          stroke="currentColor"
          stroke-width="1.5"
