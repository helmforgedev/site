---
interface Props {
  mode: 'production' | 'ha';
}

const { mode } = Astro.props;
---

<svg
  viewBox="0 0 760 360"
  class="w-full max-w-[760px] h-auto"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label={`Keycloak ${mode} architecture diagram`}
>
  <style>
    .diagram-text {
      font-family: ui-monospace, monospace;
      font-size: 11px;
    }
    .diagram-label {
      font-family: ui-sans-serif, system-ui, sans-serif;
      font-size: 10px;
    }
    .muted {
      opacity: 0.55;
    }
  </style>

  {
    mode === 'production' ? (
      <g>
        <rect x="20" y="40" width="96" height="44" rx="8" fill="none" stroke="currentColor" stroke-width="1.5" />
        <text x="68" y="58" text-anchor="middle" fill="currentColor" class="diagram-text">
          Users
        </text>
        <text x="68" y="72" text-anchor="middle" fill="currentColor" class="diagram-label muted">
          HTTPS/OIDC
        </text>

        <line x1="116" y1="62" x2="162" y2="62" stroke="currentColor" stroke-width="1.5" />
        <polygon points="162,57 172,62 162,67" fill="currentColor" />

        <rect
          x="172"
          y="32"
          width="126"
          height="60"
          rx="8"
          fill="currentColor"
          fill-opacity="0.04"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-dasharray="6 3"
        />
        <text x="235" y="55" text-anchor="middle" fill="currentColor" class="diagram-text">
          Ingress or
        </text>
        <text x="235" y="70" text-anchor="middle" fill="currentColor" class="diagram-text">
          HTTPRoute
        </text>

        <line x1="298" y1="62" x2="350" y2="62" stroke="currentColor" stroke-width="1.5" />
        <polygon points="350,57 360,62 350,67" fill="currentColor" />

        <rect
          x="360"
          y="32"
          width="128"
          height="60"
          rx="8"
          fill="currentColor"
          fill-opacity="0.06"
          stroke="currentColor"
          stroke-width="1.5"
        />
        <text x="424" y="55" text-anchor="middle" fill="currentColor" class="diagram-text">
          App Service
        </text>
        <text x="424" y="70" text-anchor="middle" fill="currentColor" class="diagram-label muted">
          :8080
        </text>

        <line x1="488" y1="62" x2="540" y2="62" stroke="currentColor" stroke-width="1.5" />
        <polygon points="540,57 550,62 540,67" fill="currentColor" />

        <rect
          x="550"
          y="25"
          width="150"
          height="74"
          rx="8"
          fill="currentColor"
          fill-opacity="0.08"
          stroke="currentColor"
          stroke-width="1.5"
        />
        <text x="625" y="50" text-anchor="middle" fill="currentColor" class="diagram-text" font-weight="bold">
          Keycloak
        </text>
        <text x="625" y="65" text-anchor="middle" fill="currentColor" class="diagram-label muted">
          Deployment
        </text>
        <text x="625" y="80" text-anchor="middle" fill="currentColor" class="diagram-label muted">
          26.6.1
        </text>

        <rect
          x="360"
          y="142"
          width="128"
          height="54"
          rx="8"
          fill="currentColor"
          fill-opacity="0.04"
          stroke="currentColor"
          stroke-width="1.5"
        />
        <text x="424" y="164" text-anchor="middle" fill="currentColor" class="diagram-text">
          Management
        </text>
        <text x="424" y="179" text-anchor="middle" fill="currentColor" class="diagram-label muted">
