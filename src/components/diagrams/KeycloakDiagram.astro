        <polygon points="491,148 488,154 496,153" fill="currentColor" />

        <rect
          x="550"
          y="142"
          width="150"
          height="54"
          rx="8"
          fill="currentColor"
          fill-opacity="0.05"
          stroke="currentColor"
          stroke-width="1.5"
        />
        <text x="625" y="164" text-anchor="middle" fill="currentColor" class="diagram-text">
          PostgreSQL
        </text>
        <text x="625" y="179" text-anchor="middle" fill="currentColor" class="diagram-label muted">
          bundled or external
        </text>

        <line x1="625" y1="99" x2="625" y2="142" stroke="currentColor" stroke-width="1.5" />
        <polygon points="620,132 625,142 630,132" fill="currentColor" />

        <rect
          x="360"
          y="244"
          width="128"
          height="54"
          rx="8"
          fill="currentColor"
          fill-opacity="0.04"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-dasharray="6 3"
        />
        <text x="424" y="266" text-anchor="middle" fill="currentColor" class="diagram-text">
          ExternalSecret
        </text>
        <text x="424" y="281" text-anchor="middle" fill="currentColor" class="diagram-label muted">
          optional
        </text>

        <line x1="488" y1="271" x2="550" y2="184" stroke="currentColor" stroke-width="1.2" stroke-dasharray="4 3" />
        <polygon points="542,189 550,184 550,193" fill="currentColor" />

        <rect
          x="550"
          y="244"
          width="150"
          height="54"
          rx="8"
          fill="currentColor"
          fill-opacity="0.04"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-dasharray="6 3"
        />
        <text x="625" y="266" text-anchor="middle" fill="currentColor" class="diagram-text">
          S3 Backup
        </text>
        <text x="625" y="281" text-anchor="middle" fill="currentColor" class="diagram-label muted">
          database dump
        </text>

        <line x1="625" y1="196" x2="625" y2="244" stroke="currentColor" stroke-width="1.2" stroke-dasharray="4 3" />
        <polygon points="620,234 625,244 630,234" fill="currentColor" />
      </g>
    ) : (
      <g>
        <rect x="20" y="62" width="96" height="44" rx="8" fill="none" stroke="currentColor" stroke-width="1.5" />
        <text x="68" y="80" text-anchor="middle" fill="currentColor" class="diagram-text">
          Users
        </text>
        <text x="68" y="94" text-anchor="middle" fill="currentColor" class="diagram-label muted">
          HTTPS/OIDC
        </text>

        <line x1="116" y1="84" x2="162" y2="84" stroke="currentColor" stroke-width="1.5" />
        <polygon points="162,79 172,84 162,89" fill="currentColor" />

        <rect
          x="172"
          y="54"
          width="126"
          height="60"
          rx="8"
