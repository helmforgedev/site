---
import { CheckCircle2, ChevronRight, Scale } from 'lucide-astro';
import Container from './Container.astro';
import { comparisonFull } from '../data/comparison';
---

<section class="bg-bg-base py-20 lg:py-28 relative border-t border-border/50">
  <!-- Subtle Gradient Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-bg-surface/30 to-bg-base pointer-events-none"></div>

  <Container class="relative">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <div class="inline-flex items-center justify-center p-3 rounded-2xl bg-primary/10 text-primary mb-6 ring-1 ring-primary/20">
        <Scale class="w-6 h-6" />
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-text-base heading-font">
        The Open-Source Standard
      </h2>
      <p class="mt-5 text-lg text-text-muted leading-relaxed">
        Official images, no vendor lock-in, MIT licensed. HelmForge provides a premium experience without enterprise paywalls.
      </p>
    </div>

    <div class="overflow-hidden rounded-3xl border border-border bg-bg-surface/40 backdrop-blur-sm shadow-2xl shadow-black/50">
      <div class="overflow-x-auto scrollbar-hide">
        <table class="w-full text-sm text-left border-collapse">
          <thead>
            <tr class="border-b border-border/80 bg-bg-surface/80">
              <th class="px-6 py-5 font-semibold text-text-muted w-[20%] uppercase tracking-wider text-xs">Features</th>
              <th class="px-6 py-5 w-[30%] bg-primary/5 border-x border-primary/10">
                <span class="flex items-center gap-2 font-bold text-primary-light text-base">
                  <CheckCircle2 class="w-5 h-5 text-primary" />
                  HelmForge
                </span>
              </th>
              <th class="px-6 py-5 font-semibold text-text-muted w-[25%] opacity-80">Bitnami</th>
              <th class="px-6 py-5 font-semibold text-text-muted w-[25%] opacity-80">Generic Community</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border/50">
            {comparisonFull.map((row) => (
              <tr class="group transition-colors hover:bg-white/[0.02]">
                <td class="px-6 py-4 font-semibold text-text-base whitespace-nowrap">{row.aspect}</td>
                <td class="px-6 py-4 text-text-base font-medium bg-primary/[0.02] border-x border-primary/10 group-hover:bg-primary/[0.04] transition-colors">
                  <span class="flex items-start gap-2">
                    <CheckCircle2 class="w-4 h-4 text-primary mt-0.5 shrink-0" />
                    <span>{row.helmforge}</span>
                  </span>
                </td>
                <td class="px-6 py-4 text-text-muted leading-relaxed">{row.bitnami}</td>
                <td class="px-6 py-4 text-text-muted leading-relaxed">{row.community}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-10 flex justify-center">
      <a
        href="/docs/comparison"
        class="group inline-flex items-center gap-2 rounded-full border border-border bg-bg-surface px-6 py-3 text-sm font-semibold text-text-base transition-all hover:border-primary/50 hover:text-primary-light hover:shadow-lg hover:shadow-primary/10"
      >
        Read the full comparison
        <ChevronRight class="w-4 h-4 transition-transform group-hover:translate-x-1" />
      </a>
    </div>
  </Container>
</section>
