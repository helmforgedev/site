---
interface Props {
  variant?: 'horizontal' | 'icon';
  class?: string;
}

const { variant = 'horizontal', class: className = '' } = Astro.props;

// Unique gradient IDs to avoid SVG ID collisions when multiple logos render on the same page
const uid = Math.random().toString(36).slice(2, 8);
const id1 = `ll-${uid}`;
const id2 = `lr-${uid}`;
const id3 = `cb-${uid}`;
---

{variant === 'icon' ? (
  <svg class={className} viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <linearGradient id={id1} x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#a78bfa" />
        <stop offset="100%" stop-color="#6d28d9" />
      </linearGradient>
      <linearGradient id={id2} x1="0%" y1="100%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#fb923c" />
        <stop offset="100%" stop-color="#ea580c" />
      </linearGradient>
      <linearGradient id={id3} x1="0%" y1="50%" x2="100%" y2="50%">
        <stop offset="0%" stop-color="#8b5cf6" />
        <stop offset="50%" stop-color="#f43f5e" />
        <stop offset="100%" stop-color="#ea580c" />
      </linearGradient>
    </defs>
    <polygon points="25,15 45,15 35,85 15,85" fill={`url(#${id1})`} />
    <polygon points="65,15 85,15 75,85 55,85" fill={`url(#${id2})`} />
    <polygon points="28,45 72,45 68,55 24,55" fill={`url(#${id3})`} />
  </svg>
) : (
  <svg class={className} viewBox="0 0 360 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <linearGradient id={id1} x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#a78bfa" />
        <stop offset="100%" stop-color="#6d28d9" />
      </linearGradient>
      <linearGradient id={id2} x1="0%" y1="100%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#fb923c" />
        <stop offset="100%" stop-color="#ea580c" />
      </linearGradient>
      <linearGradient id={id3} x1="0%" y1="50%" x2="100%" y2="50%">
        <stop offset="0%" stop-color="#8b5cf6" />
        <stop offset="50%" stop-color="#f43f5e" />
        <stop offset="100%" stop-color="#ea580c" />
      </linearGradient>
    </defs>
    <polygon points="25,15 45,15 35,85 15,85" fill={`url(#${id1})`} />
    <polygon points="65,15 85,15 75,85 55,85" fill={`url(#${id2})`} />
    <polygon points="28,45 72,45 68,55 24,55" fill={`url(#${id3})`} />
    <text x="110" y="66" font-family="'Outfit', system-ui, sans-serif" font-size="46" font-weight="700" fill="currentColor">
      Helm<tspan fill="#f97316">Forge</tspan>
    </text>
  </svg>
)}
