---
import Container from './Container.astro';
import { comparisonSummary } from '../data/comparison';
---

<section class="py-20 lg:py-28 relative overflow-hidden bg-bg-base">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-primary/20 blur-[120px] rounded-full pointer-events-none"></div>

  <Container class="relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-5xl font-extrabold text-text-base tracking-tight heading-font">
        HelmForge vs The Ecosystem
      </h2>
      <p class="mt-4 text-xl text-text-muted max-w-2xl mx-auto">
        A direct comparison of design choices over generic community charts and enterprise alternatives like Bitnami.
      </p>
    </div>

    <div class="glass-panel rounded-2xl overflow-hidden border border-border shadow-2xl">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[800px]">
          <caption class="sr-only">Summary comparison of HelmForge vs generic charts and Bitnami</caption>
          <thead>
            <tr class="bg-bg-surface border-b border-border">
              <th class="py-5 px-6 font-semibold text-text-muted uppercase tracking-wider text-xs w-1/4">Aspect</th>
              <th class="py-5 px-6 font-semibold text-text-muted uppercase tracking-wider text-xs w-1/4">Generic Charts</th>
              <th class="py-5 px-6 font-semibold text-text-muted uppercase tracking-wider text-xs w-1/4">Bitnami</th>
              <th class="py-5 px-6 font-bold text-primary-light uppercase tracking-wider text-xs w-1/4 bg-primary/5 border-l border-primary/20">HelmForge</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            {comparisonSummary.map((item) => (
              <tr class="transition-colors hover:bg-text-base/5">
                <td class="py-5 px-6 text-sm font-semibold text-text-base">
                  {item.feature}
                </td>
                <td class="py-5 px-6 text-sm text-text-muted">
                  {item.generic}
                </td>
                <td class="py-5 px-6 text-sm text-text-muted">
                  {item.bitnami}
                </td>
                <td class="py-5 px-6 text-sm font-medium text-text-base bg-primary/5 border-l border-primary/20">
                  {item.helmforge}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </Container>
</section>
