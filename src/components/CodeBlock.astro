---
import CopyButton from './CopyButton.astro';

interface Props {
  code: string;
  lang?: string;
}

const { code, lang = 'bash' } = Astro.props;
const id = `code-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="relative group rounded-xl overflow-hidden bg-slate-900 border border-slate-700/50 shadow-lg my-4">
  <!-- Language badge -->
  <div class="flex items-center justify-between px-4 py-2 border-b border-slate-700/50">
    <span class="text-xs font-mono text-slate-500 uppercase tracking-wider">{lang}</span>
    <CopyButton targetId={id} />
  </div>

  <!-- Code content -->
  <pre
    class="px-5 py-4 overflow-x-auto text-sm leading-relaxed"><code id={id} class="text-slate-300 font-mono">{code}</code></pre>
</div>
