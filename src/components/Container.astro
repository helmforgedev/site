---
interface Props {
  maxWidth?: '6xl' | '7xl';
  class?: string;
}

const { maxWidth = '7xl', class: className = '' } = Astro.props;

const widthClass = maxWidth === '6xl' ? 'max-w-6xl' : 'max-w-7xl';
---

<div class:list={[widthClass, 'mx-auto px-4 sm:px-6 lg:px-8', className]}>
  <slot />
</div>
