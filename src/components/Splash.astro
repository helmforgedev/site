<div id="splash-screen" class="fixed inset-0 z-[100] flex items-center justify-center bg-bg-base transition-opacity duration-1000 ease-in-out">
  <div class="relative w-48 h-48 sm:w-64 sm:h-64">
    <!-- SVG animation mimicking the concept B containers -->
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" class="w-full h-full animate-pulse-logo">
      <path 
        d="M25 15 L40 5 L40 65 L25 75 Z M40 5 L55 15 L55 75 L40 65 Z M60 25 L75 15 L75 75 L60 85 Z M75 15 L90 25 L90 85 L75 75 Z M40 45 L60 30 L75 40 L55 55 Z" 
        fill="none" 
        stroke="url(#splashGrad)" 
        stroke-width="5" 
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-dasharray="500" 
        stroke-dashoffset="500" 
        class="animate-draw" 
      />
      <defs>
        <linearGradient id="splashGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#f97316;stop-opacity:1" /> <!-- Orange -->
          <stop offset="100%" style="stop-color:#8b5cf6;stop-opacity:1" /> <!-- Purple -->
        </linearGradient>
      </defs>
    </svg>
  </div>
</div>

<style>
  .animate-draw {
    animation: draw 2.2s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }
  
  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  
  .animate-pulse-logo {
    animation: pulseLogo 1.5s infinite alternate ease-in-out;
  }
  
  @keyframes pulseLogo {
    0% { transform: scale(0.95); opacity: 0.8; filter: drop-shadow(0 0 10px rgba(249, 115, 22, 0.3)); }
    100% { transform: scale(1.05); opacity: 1; filter: drop-shadow(0 0 25px rgba(139, 92, 246, 0.6)); }
  }
</style>

<script is:inline>
  // Immediately lock scrolling to prevent interaction while splash is active
  document.documentElement.style.overflow = 'hidden';
  document.documentElement.style.height = '100vh';

  document.addEventListener('DOMContentLoaded', () => {
    const splash = document.getElementById('splash-screen');
    if (splash) {
      setTimeout(() => {
        splash.style.opacity = '0';
        splash.style.pointerEvents = 'none';
        
        // Restore scrolling when animation begins to fade
        document.documentElement.style.overflow = '';
        document.documentElement.style.height = '';
        
        setTimeout(() => splash.remove(), 1000);
      }, 2000);
    } else {
      document.documentElement.style.overflow = '';
      document.documentElement.style.height = '';
    }
  });
</script>
