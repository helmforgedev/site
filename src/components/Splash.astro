---
import Logo from './Logo.astro';
---

<div id="splash-screen" class="fixed inset-0 z-[100] flex items-center justify-center bg-bg-base transition-opacity duration-1000 ease-in-out">
  <div class="relative w-48 h-48 sm:w-64 sm:h-64">
    <Logo variant="icon" class="w-full h-full splash-logo" />
  </div>
</div>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .splash-logo {
      animation: pulseLogo 1.5s infinite alternate ease-in-out;
    }
  }

  @keyframes pulseLogo {
    0% { transform: scale(0.95); opacity: 0.8; filter: drop-shadow(0 0 10px var(--color-accent-light, rgba(249, 115, 22, 0.3))); }
    100% { transform: scale(1.05); opacity: 1; filter: drop-shadow(0 0 25px var(--color-primary, rgba(139, 92, 246, 0.6))); }
  }
</style>

<script is:inline>
  document.documentElement.style.overflow = 'hidden';
  document.documentElement.style.height = '100vh';

  document.addEventListener('DOMContentLoaded', () => {
    const splash = document.getElementById('splash-screen');
    // Skip animation for users who prefer reduced motion
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const delay = prefersReduced ? 0 : 1500;

    if (splash) {
      setTimeout(() => {
        splash.style.opacity = '0';
        splash.style.pointerEvents = 'none';
        document.documentElement.style.overflow = '';
        document.documentElement.style.height = '';
        setTimeout(() => splash.remove(), prefersReduced ? 0 : 1000);
      }, delay);
    } else {
      document.documentElement.style.overflow = '';
      document.documentElement.style.height = '';
    }
  });
</script>
