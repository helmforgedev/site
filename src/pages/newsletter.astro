---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Container from '../components/Container.astro';
---

<BaseLayout
  title="Newsletter"
  description="Subscribe to the HelmForge newsletter and receive practical Kubernetes and Helm chart updates."
>
  <Header />
  <main id="main-content" class="py-16 sm:py-20" data-pagefind-body>
    <Container>
      <section class="mx-auto max-w-3xl glass-panel rounded-2xl p-6 sm:p-8 lg:p-10">
        <p class="text-xs uppercase tracking-wider text-text-muted mb-3" data-i18n="newsletter.label">
          HelmForge Newsletter
        </p>
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-text-base heading-font">
          <span data-i18n="newsletter.title">Stay ahead with practical Kubernetes updates</span>
        </h1>
        <p class="mt-4 text-base text-text-muted leading-relaxed" data-i18n="newsletter.description">
          Receive curated Helm and Kubernetes content, new chart releases, and production tips from HelmForge.
        </p>
        <form
          method="post"
          action="https://newsletter.helmforge.dev/subscription/form"
          target="_blank"
          class="mt-8 rounded-xl border border-border bg-bg-surface/60 p-5 sm:p-6"
          aria-label="HelmForge newsletter form"
          data-i18n-attr="aria-label"
          data-i18n-key="newsletter.form.aria"
        >
          <input type="hidden" name="nonce" />

          <label class="block text-sm font-medium text-text-base mb-2" for="newsletter-email" data-i18n="newsletter.form.email">
            E-mail
          </label>
          <input
            id="newsletter-email"
            type="email"
            name="email"
            required
            placeholder="you@company.com"
            data-i18n-attr="placeholder"
            data-i18n-key="newsletter.form.emailPlaceholder"
            class="w-full rounded-lg border border-border bg-bg-base px-3 py-2.5 text-text-base placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-primary/40"
          />

          <label
            class="mt-4 block text-sm font-medium text-text-base mb-2"
            for="newsletter-name"
            data-i18n="newsletter.form.name">Name (optional)</label
          >
          <input
            id="newsletter-name"
            type="text"
            name="name"
            placeholder="Your name"
            data-i18n-attr="placeholder"
            data-i18n-key="newsletter.form.namePlaceholder"
            class="w-full rounded-lg border border-border bg-bg-base px-3 py-2.5 text-text-base placeholder:text-text-muted/70 focus:outline-none focus:ring-2 focus:ring-primary/40"
          />

          <div class="mt-5 rounded-lg border border-border bg-bg-base/70 p-4">
            <div class="flex items-start gap-2">
              <input
                id="list-helmforge-newsletter"
                type="checkbox"
                name="l"
                checked
                value="7f91e9db-d5f1-4999-83fd-a908208bd8d5"
                class="mt-1 h-4 w-4 rounded border-border text-primary focus:ring-primary/40"
              />
              <div>
                <label for="list-helmforge-newsletter" class="text-sm font-semibold text-text-base">
                  <span data-i18n="newsletter.form.listTitle">HelmForge Newsletter</span>
                </label>
                <p class="mt-1 text-sm text-text-muted" data-i18n="newsletter.form.listDescription">
                  Official HelmForge newsletter with Kubernetes insights, chart updates, and release notes.
                </p>
              </div>
            </div>
          </div>

          <div class="mt-5">
            <altcha-widget challengeurl="https://newsletter.helmforge.dev/api/public/captcha/altcha"></altcha-widget>
          </div>

          <div class="mt-5 flex flex-wrap items-center gap-3">
            <button
              type="submit"
              class="inline-flex items-center gap-2 rounded-lg border border-primary/40 bg-primary/10 px-4 py-2 text-sm font-semibold text-primary-light hover:bg-primary/20 transition-colors"
            >
              <span data-i18n="newsletter.form.subscribe">Subscribe</span>
            </button>
            <a
              href="/rss.xml"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-border px-4 py-2 text-sm font-semibold text-text-base hover:border-primary/40 hover:text-primary-light transition-colors"
              aria-label="Subscribe via RSS"
              data-i18n-attr="aria-label"
              data-i18n-key="newsletter.form.rssAria"
            >
              <span data-i18n="newsletter.form.rss">Subscribe via RSS</span>
            </a>
          </div>
        </form>
      </section>
    </Container>
  </main>
  <script type="module" src="https://newsletter.helmforge.dev/public/static/altcha.umd.js" async defer></script>
  <Footer />
</BaseLayout>
