// Field definition for playground configs
interface PlaygroundField {
  label: string;
  key: string;
  type: 'text' | 'number' | 'select' | 'toggle';
  default: string;
  options?: string[];
  description: string;
}

// Group definition with optional collapsible behavior
interface PlaygroundGroup {
  name: string;
  collapsible?: boolean;
  gateField?: string; // e.g. "backup.enabled" — toggles section visibility AND sets this value
  fields: PlaygroundField[];
}

// Chart configuration using explicit groups
