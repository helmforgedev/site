---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props.frontmatter || Astro.props;

const currentPath = Astro.url.pathname;

const sidebarNav = [
  { label: 'Getting Started', href: '/docs/getting-started' },
  { label: 'Charts Overview', href: '/docs/charts' },
  { label: 'Stack Examples', href: '/docs/stack-examples' },
  { label: 'HelmForge vs Other Charts', href: '/docs/comparison' },
];

const chartNav = [
  { label: 'Generic', href: '/docs/charts/generic' },
  { label: 'MySQL', href: '/docs/charts/mysql' },
  { label: 'PostgreSQL', href: '/docs/charts/postgresql' },
  { label: 'Redis', href: '/docs/charts/redis' },
  { label: 'MongoDB', href: '/docs/charts/mongodb' },
  { label: 'RabbitMQ', href: '/docs/charts/rabbitmq' },
  { label: 'Keycloak', href: '/docs/charts/keycloak' },
  { label: 'Vaultwarden', href: '/docs/charts/vaultwarden' },
  { label: 'Minecraft', href: '/docs/charts/minecraft' },
  { label: 'Pi-hole', href: '/docs/charts/pihole' },
  { label: 'WordPress', href: '/docs/charts/wordpress' },
  { label: 'Strapi', href: '/docs/charts/strapi' },
  { label: 'Answer', href: '/docs/charts/answer' },
  { label: 'n8n', href: '/docs/charts/n8n' },
  { label: 'Komga', href: '/docs/charts/komga' },
  { label: 'Guacamole', href: '/docs/charts/guacamole' },
  { label: 'Cloudflared', href: '/docs/charts/cloudflared' },
  { label: 'DDNS Updater', href: '/docs/charts/ddns-updater' },
  { label: 'Uptime Kuma', href: '/docs/charts/uptime-kuma' },
  { label: 'Appwrite', href: '/docs/charts/appwrite' },
  { label: 'Authelia', href: '/docs/charts/authelia' },
  { label: 'AdGuard Home', href: '/docs/charts/adguard-home' },
  { label: 'Velero', href: '/docs/charts/velero' },
  { label: 'Kafka', href: '/docs/charts/kafka' },
  { label: 'Dolibarr', href: '/docs/charts/dolibarr' },
  { label: 'Mosquitto', href: '/docs/charts/mosquitto' },
  { label: 'Docmost', href: '/docs/charts/docmost' },
  { label: 'Flowise', href: '/docs/charts/flowise' },
  { label: 'phpMyAdmin', href: '/docs/charts/phpmyadmin' },
  { label: 'Heimdall', href: '/docs/charts/heimdall' },
  { label: 'Gitea', href: '/docs/charts/gitea' },
  { label: 'Homarr', href: '/docs/charts/homarr' },
  { label: 'MariaDB', href: '/docs/charts/mariadb' },
];

const allPages = [
  { label: 'Documentation', href: '/docs' },
  ...sidebarNav,
  ...chartNav,
];

const currentIndex = allPages.findIndex(p =>
  currentPath.replace(/\/$/, '') === p.href.replace(/\/$/, '')
);
const prevPage = currentIndex > 0 ? allPages[currentIndex - 1] : null;
const nextPage = currentIndex < allPages.length - 1 ? allPages[currentIndex + 1] : null;

// Build breadcrumbs
const segments = currentPath.split('/').filter(Boolean);
const breadcrumbs = segments.map((seg, i) => ({
  label: seg.charAt(0).toUpperCase() + seg.slice(1).replace(/-/g, ' '),
  href: '/' + segments.slice(0, i + 1).join('/'),
  isLast: i === segments.length - 1,
}));

function isActive(href: string): boolean {
  const clean = currentPath.replace(/\/$/, '');
  const target = href.replace(/\/$/, '');
  return clean === target;
}
---

<BaseLayout title={title} description={description}>
  <Header />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
    <!-- Mobile sidebar toggle -->
    <button
      id="docs-sidebar-toggle"
      class="lg:hidden mb-4 flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-muted transition-colors hover:bg-slate-50"
      aria-label="Toggle sidebar navigation"
      aria-expanded="false"
      aria-controls="docs-sidebar"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      Menu
    </button>

    <div class="lg:grid lg:grid-cols-[248px_minmax(0,1fr)] lg:gap-12">
      <!-- Sidebar -->
      <aside id="docs-sidebar" class="hidden lg:block">
        <nav class="sticky top-24 space-y-6 rounded-2xl border border-slate-200 bg-white p-4">
          <!-- Breadcrumbs (desktop) -->
          <div class="hidden lg:flex flex-wrap items-center gap-1.5 border-b border-slate-100 pb-4 text-sm text-muted">
            <a href="/" class="hover:text-primary transition-colors">Home</a>
            {breadcrumbs.map(crumb => (
              <>
                <span class="text-slate-300">/</span>
                {crumb.isLast ? (
                  <span class="text-dark font-medium">{crumb.label}</span>
                ) : (
                  <a href={crumb.href} class="hover:text-primary transition-colors">{crumb.label}</a>
                )}
              </>
            ))}
          </div>

          <div>
            <h3 class="mb-2 px-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-muted">Documentation</h3>
            <ul class="space-y-1">
              <li>
                <a
                  href="/docs"
                  class:list={[
                    'block rounded-lg px-3 py-2 text-sm transition-colors',
                    isActive('/docs')
                      ? 'bg-primary/8 text-primary font-medium'
                      : 'text-slate-600 hover:bg-slate-50 hover:text-dark',
                  ]}
                >
                  Overview
                </a>
              </li>
              {sidebarNav.map(item => (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      'block rounded-lg px-3 py-2 text-sm transition-colors',
                      isActive(item.href)
                        ? 'bg-primary/8 text-primary font-medium'
                        : 'text-slate-600 hover:bg-slate-50 hover:text-dark',
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <div class="mb-2 flex items-center justify-between px-2">
              <h3 class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted">Charts</h3>
              <a href="/docs/charts" class="text-xs font-medium text-primary hover:text-primary-dark transition-colors">View all</a>
            </div>
            <ul class="max-h-[32rem] space-y-1 overflow-y-auto pr-1">
              {chartNav.map(item => (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      'block rounded-lg px-3 py-2 text-sm transition-colors',
                      isActive(item.href)
                        ? 'bg-primary/8 text-primary font-medium'
                        : 'text-slate-600 hover:bg-slate-50 hover:text-dark',
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </nav>
      </aside>

      <!-- Main content -->
      <main class="min-w-0">
        <!-- Breadcrumbs (mobile) -->
        <div class="mb-6 flex flex-wrap items-center gap-1.5 text-sm text-muted lg:hidden">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          {breadcrumbs.map(crumb => (
            <>
              <span class="text-slate-300">/</span>
              {crumb.isLast ? (
                <span class="text-dark font-medium">{crumb.label}</span>
              ) : (
                <a href={crumb.href} class="hover:text-primary transition-colors">{crumb.label}</a>
              )}
            </>
            ))}
        </div>

        <article class="rounded-2xl border border-slate-200 bg-white px-5 py-8 shadow-sm sm:px-8 lg:px-10">
          <div class="prose prose-docs max-w-3xl">
            <slot />
          </div>
        </article>

        <!-- Prev / Next navigation -->
        <nav class="mt-8 grid gap-3 border-t border-slate-200 pt-6 sm:grid-cols-2">
          {prevPage ? (
            <a
              href={prevPage.href}
              class="group flex min-h-[84px] flex-col justify-center rounded-2xl border border-slate-200 bg-white px-5 py-4 text-sm transition-colors hover:border-slate-300 hover:text-primary"
            >
              <span class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.16em] text-muted">
                <svg class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
                Previous
              </span>
              <span class="mt-2 text-base font-semibold text-dark">{prevPage.label}</span>
            </a>
          ) : <span class="hidden sm:block" />}
          {nextPage ? (
            <a
              href={nextPage.href}
              class="group flex min-h-[84px] flex-col justify-center rounded-2xl border border-slate-200 bg-white px-5 py-4 text-sm transition-colors hover:border-slate-300 hover:text-primary sm:text-right"
            >
              <span class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.16em] text-muted sm:justify-end">
                Next
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
              <span class="mt-2 text-base font-semibold text-dark">{nextPage.label}</span>
            </a>
          ) : <span class="hidden sm:block" />}
        </nav>
      </main>
    </div>
  </div>

  <Footer />

  <script is:inline>
    (() => {
      const toggle = document.getElementById('docs-sidebar-toggle');
      const sidebar = document.getElementById('docs-sidebar');
      if (toggle && sidebar) {
        toggle.addEventListener('click', () => {
          sidebar.classList.toggle('hidden');
          sidebar.classList.toggle('block');
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!expanded));
        });
      }

      // Inject copy buttons into all prose code blocks
      document.querySelectorAll('.prose-docs pre').forEach(pre => {
        if (pre.querySelector('.prose-copy-btn')) return;
        const btn = document.createElement('button');
        btn.className = 'prose-copy-btn';
        btn.setAttribute('aria-label', 'Copy code');
        btn.innerHTML = '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg><span>Copy</span>';
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code');
          if (!code) return;
          try {
            await navigator.clipboard.writeText(code.textContent || '');
            btn.querySelector('span').textContent = 'Copied!';
            btn.querySelector('svg').innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>';
            setTimeout(() => {
              btn.querySelector('span').textContent = 'Copy';
              btn.querySelector('svg').innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>';
            }, 2000);
          } catch (err) { console.error('Copy failed:', err); }
        });
        pre.appendChild(btn);
      });
    })();
  </script>
</BaseLayout>
