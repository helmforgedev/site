---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props.frontmatter || Astro.props;

const currentPath = Astro.url.pathname;

const sidebarNav = [
  { label: 'Getting Started', href: '/docs/getting-started' },
  { label: 'Charts Overview', href: '/docs/charts' },
];

const chartNav = [
  { label: 'Generic', href: '/docs/charts/generic' },
  { label: 'MySQL', href: '/docs/charts/mysql' },
  { label: 'PostgreSQL', href: '/docs/charts/postgresql' },
  { label: 'Redis', href: '/docs/charts/redis' },
  { label: 'MongoDB', href: '/docs/charts/mongodb' },
  { label: 'RabbitMQ', href: '/docs/charts/rabbitmq' },
  { label: 'Keycloak', href: '/docs/charts/keycloak' },
  { label: 'Vaultwarden', href: '/docs/charts/vaultwarden' },
  { label: 'Minecraft', href: '/docs/charts/minecraft' },
  { label: 'Pi-hole', href: '/docs/charts/pihole' },
  { label: 'WordPress', href: '/docs/charts/wordpress' },
  { label: 'Strapi', href: '/docs/charts/strapi' },
  { label: 'Answer', href: '/docs/charts/answer' },
  { label: 'n8n', href: '/docs/charts/n8n' },
  { label: 'Komga', href: '/docs/charts/komga' },
  { label: 'Guacamole', href: '/docs/charts/guacamole' },
  { label: 'Cloudflared', href: '/docs/charts/cloudflared' },
  { label: 'DDNS Updater', href: '/docs/charts/ddns-updater' },
  { label: 'Uptime Kuma', href: '/docs/charts/uptime-kuma' },
  { label: 'Authelia', href: '/docs/charts/authelia' },
  { label: 'AdGuard Home', href: '/docs/charts/adguard-home' },
  { label: 'Velero', href: '/docs/charts/velero' },
];

const allPages = [
  { label: 'Documentation', href: '/docs' },
  ...sidebarNav,
  ...chartNav,
];

const currentIndex = allPages.findIndex(p =>
  currentPath.replace(/\/$/, '') === p.href.replace(/\/$/, '')
);
const prevPage = currentIndex > 0 ? allPages[currentIndex - 1] : null;
const nextPage = currentIndex < allPages.length - 1 ? allPages[currentIndex + 1] : null;

// Build breadcrumbs
const segments = currentPath.split('/').filter(Boolean);
const breadcrumbs = segments.map((seg, i) => ({
  label: seg.charAt(0).toUpperCase() + seg.slice(1).replace(/-/g, ' '),
  href: '/' + segments.slice(0, i + 1).join('/'),
  isLast: i === segments.length - 1,
}));

function isActive(href: string): boolean {
  const clean = currentPath.replace(/\/$/, '');
  const target = href.replace(/\/$/, '');
  return clean === target;
}
---

<BaseLayout title={title} description={description}>
  <Header />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Mobile sidebar toggle -->
    <button
      id="docs-sidebar-toggle"
      class="lg:hidden mb-4 flex items-center gap-2 px-3 py-2 text-sm font-medium text-muted bg-surface rounded-lg border border-slate-200 hover:bg-slate-100 transition-colors"
      aria-label="Toggle sidebar navigation"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      Menu
    </button>

    <div class="lg:grid lg:grid-cols-[260px_1fr] lg:gap-10">
      <!-- Sidebar -->
      <aside id="docs-sidebar" class="hidden lg:block">
        <nav class="sticky top-24 space-y-6">
          <!-- Breadcrumbs (desktop) -->
          <div class="hidden lg:flex items-center gap-1.5 text-sm text-muted mb-4">
            <a href="/" class="hover:text-primary transition-colors">Home</a>
            {breadcrumbs.map(crumb => (
              <>
                <span class="text-slate-300">/</span>
                {crumb.isLast ? (
                  <span class="text-dark font-medium">{crumb.label}</span>
                ) : (
                  <a href={crumb.href} class="hover:text-primary transition-colors">{crumb.label}</a>
                )}
              </>
            ))}
          </div>

          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-muted mb-2">Documentation</h3>
            <ul class="space-y-1">
              <li>
                <a
                  href="/docs"
                  class:list={[
                    'block px-3 py-1.5 rounded-md text-sm transition-colors',
                    isActive('/docs')
                      ? 'bg-primary/10 text-primary font-medium'
                      : 'text-slate-600 hover:bg-slate-100 hover:text-dark',
                  ]}
                >
                  Overview
                </a>
              </li>
              {sidebarNav.map(item => (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      'block px-3 py-1.5 rounded-md text-sm transition-colors',
                      isActive(item.href)
                        ? 'bg-primary/10 text-primary font-medium'
                        : 'text-slate-600 hover:bg-slate-100 hover:text-dark',
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-muted mb-2">Charts</h3>
            <ul class="space-y-1">
              {chartNav.map(item => (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      'block px-3 py-1.5 rounded-md text-sm transition-colors',
                      isActive(item.href)
                        ? 'bg-primary/10 text-primary font-medium'
                        : 'text-slate-600 hover:bg-slate-100 hover:text-dark',
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </nav>
      </aside>

      <!-- Main content -->
      <main class="min-w-0">
        <!-- Breadcrumbs (mobile) -->
        <div class="flex lg:hidden items-center gap-1.5 text-sm text-muted mb-6 flex-wrap">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          {breadcrumbs.map(crumb => (
            <>
              <span class="text-slate-300">/</span>
              {crumb.isLast ? (
                <span class="text-dark font-medium">{crumb.label}</span>
              ) : (
                <a href={crumb.href} class="hover:text-primary transition-colors">{crumb.label}</a>
              )}
            </>
          ))}
        </div>

        <article class="prose max-w-none">
          <slot />
        </article>

        <!-- Prev / Next navigation -->
        <nav class="mt-12 pt-6 border-t border-slate-200 flex justify-between items-center gap-4">
          {prevPage ? (
            <a
              href={prevPage.href}
              class="group flex items-center gap-2 text-sm text-muted hover:text-primary transition-colors"
            >
              <svg class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
              {prevPage.label}
            </a>
          ) : <span />}
          {nextPage ? (
            <a
              href={nextPage.href}
              class="group flex items-center gap-2 text-sm text-muted hover:text-primary transition-colors ml-auto"
            >
              {nextPage.label}
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ) : <span />}
        </nav>
      </main>
    </div>
  </div>

  <Footer />

  <script is:inline>
    (() => {
      const toggle = document.getElementById('docs-sidebar-toggle');
      const sidebar = document.getElementById('docs-sidebar');
      if (toggle && sidebar) {
        toggle.addEventListener('click', () => {
          sidebar.classList.toggle('hidden');
          sidebar.classList.toggle('block');
        });
      }

      // Inject copy buttons into all prose code blocks
      document.querySelectorAll('.prose pre').forEach(pre => {
        if (pre.querySelector('.prose-copy-btn')) return;
        const btn = document.createElement('button');
        btn.className = 'prose-copy-btn';
        btn.setAttribute('aria-label', 'Copy code');
        btn.innerHTML = '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg><span>Copy</span>';
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code');
          if (!code) return;
          try {
            await navigator.clipboard.writeText(code.textContent || '');
            btn.querySelector('span').textContent = 'Copied!';
            btn.querySelector('svg').innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>';
            setTimeout(() => {
              btn.querySelector('span').textContent = 'Copy';
              btn.querySelector('svg').innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>';
            }, 2000);
          } catch (err) { console.error('Copy failed:', err); }
        });
        pre.appendChild(btn);
      });
    })();
  </script>
</BaseLayout>
